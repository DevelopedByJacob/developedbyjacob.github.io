---
import apps from '../data/apps.json';
import AppCard from './AppCard.astro';

const numCols = 3;
const indexed = apps.map((app, globalIndex) => ({ app, globalIndex }));
const columns: typeof indexed[] = Array.from({ length: numCols }, () => []);
indexed.forEach((item, i) => {
  columns[i % numCols].push(item);
});
---

<section id="apps" class="section-spacing">
  <div class="container-app">
    <div class="text-center mb-12">
      <span class="text-accent-600 dark:text-accent-400 font-mono text-xs tracking-widest uppercase">My Work</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-2">Android Apps</h2>
      <p class="text-gray-500 dark:text-gray-400 mt-3 max-w-md mx-auto">
        A collection of apps built with Kotlin and Jetpack Compose
      </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-6">
      {columns.map((col) => (
        <div class="flex flex-col gap-6 lg:flex-1 lg:min-w-0">
          {col.map(({ app, globalIndex }) => (
            <AppCard app={app} index={globalIndex} />
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
