<section class="py-14 md:py-18 bg-gray-50 dark:bg-gray-900/50">
  <div class="container-app">
    <div class="grid grid-cols-3 gap-6 max-w-2xl mx-auto text-center">
      <div class="stat-item">
        <div class="text-3xl sm:text-4xl font-extrabold gradient-text tabular-nums" data-target="8" data-suffix="">0</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1 font-medium">Apps Built</div>
      </div>
      <div class="stat-item">
        <div class="text-3xl sm:text-4xl font-extrabold gradient-text tabular-nums" data-target="50" data-suffix="K+">0</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1 font-medium">Downloads</div>
      </div>
      <div class="stat-item">
        <div class="text-3xl sm:text-4xl font-extrabold gradient-text tabular-nums" data-target="4.8" data-suffix="">0</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1 font-medium">Avg Rating</div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var items = document.querySelectorAll('.stat-item');
    if (items.length === 0) return;

    function animate(el) {
      var num = el.querySelector('[data-target]');
      if (!num || num.dataset.animated) return;
      var target = parseFloat(num.dataset.target);
      var suffix = num.dataset.suffix || '';
      var isFloat = target % 1 !== 0;
      var duration = 1600;
      var start = performance.now();
      num.dataset.animated = 'true';

      function update(now) {
        var elapsed = now - start;
        var progress = Math.min(elapsed / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        var current = eased * target;
        num.textContent = (isFloat ? current.toFixed(1) : Math.floor(current)) + suffix;
        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }

      requestAnimationFrame(update);
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          animate(entry.target);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.6 });

    items.forEach(function(item) {
      observer.observe(item);
    });
  })();
</script>
