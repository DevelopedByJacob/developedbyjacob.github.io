---
interface Props {
  screenshots: string[];
  appName: string;
}

const { screenshots, appName } = Astro.props;
const id = appName.toLowerCase().replace(/\s+/g, '-');
---

<div class="relative" id={`carousel-${id}`}>
  <div class="overflow-hidden rounded-xl bg-gray-100 dark:bg-gray-800">
    <div
      class="carousel-track"
      id={`track-${id}`}
      data-index="0"
    >
      {screenshots.map((src, i) => (
        <div class="w-full shrink-0">
          <img
            src={src}
            alt={`${appName} screenshot ${i + 1}`}
            class="w-full h-auto max-h-96 object-contain p-2"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>

  {screenshots.length > 1 && (
    <>
      <button
        id={`prev-${id}`}
        class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/90 dark:bg-gray-900/90 shadow-lg flex items-center justify-center hover:scale-110 transition-transform"
        aria-label="Previous screenshot"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id={`next-${id}`}
        class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/90 dark:bg-gray-900/90 shadow-lg flex items-center justify-center hover:scale-110 transition-transform"
        aria-label="Next screenshot"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <div class="flex justify-center gap-1.5 mt-3" id={`dots-${id}`}>
        {screenshots.map((_, i) => (
          <button
            class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-accent-500 w-5' : 'bg-gray-300 dark:bg-gray-600'}`}
            data-dot={i}
            aria-label={`Go to screenshot ${i + 1}`}
          />
        ))}
      </div>
    </>
  )}
</div>

<script define:vars={{ id, total: screenshots.length }}>
  const track = document.getElementById(`track-${id}`);
  const prev = document.getElementById(`prev-${id}`);
  const next = document.getElementById(`next-${id}`);
  const dots = document.querySelectorAll(`#dots-${id} [data-dot]`);

  if (track) {
    let current = 0;

    function goTo(index) {
      current = index;
      track.style.transform = `translateX(-${current * 100}%)`;
      track.setAttribute('data-index', String(current));

      dots.forEach((dot, i) => {
        dot.className =
          i === current
            ? 'w-5 h-2 rounded-full transition-all duration-300 bg-accent-500'
            : 'w-2 h-2 rounded-full transition-all duration-300 bg-gray-300 dark:bg-gray-600';
      });
    }

    if (prev) {
      prev.addEventListener('click', () => {
        goTo(current === 0 ? total - 1 : current - 1);
      });
    }

    if (next) {
      next.addEventListener('click', () => {
        goTo(current === total - 1 ? 0 : current + 1);
      });
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(Number(dot.getAttribute('data-dot')));
      });
    });
  }
</script>
